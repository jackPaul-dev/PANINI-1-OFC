# Banco de dados PostgreSQL
# Atenção Heroku: adicionar ?sslmode=require&channel_binding=disable
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require&channel_binding=disable

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# E-mail (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=Panini USA <noreply@seudominio.com>

# URL base para links de rastreamento nos e-mails
TRACKING_BASE_URL=https://seudominio.com

# Meta Conversions API (CAPI) — server-side
META_PIXEL_ACCESS_TOKEN=EAAN...

# Nota: VITE_STRIPE_PUBLISHABLE_KEY (pk_live_...) é embutida no build
# do frontend via variável de ambiente no momento do "pnpm run build".
# Não é usada em runtime pelo servidor.
